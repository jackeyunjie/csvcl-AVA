# Copy this file to .env and fill in your own values.
# .env is ignored by Git; never commit real credentials.

# -----------------------------------------------------------------------------
# MT4 CSV data source
# -----------------------------------------------------------------------------
# Full path to the MT4 MQL4/Files folder where KVB CSV files are written.
# Example (matches the current MT4 terminal directory on this machine):
# MT4_FILES_PATH=C:\Users\MECHREVO\AppData\Roaming\MetaQuotes\Terminal\1F7FB83FCE28CDC848B46CF4612D1D35\MQL4\Files
MT4_FILES_PATH=

# Alternative: path to the YAML configuration file used by ConfigManager.
# MT4_CONFIG_PATH=configs/mt4_config.yaml

# -----------------------------------------------------------------------------
# Email (used as fallback when email_config.ini is not present or incomplete)
# -----------------------------------------------------------------------------
EMAIL_SMTP_SERVER=smtp.qq.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email@qq.com
EMAIL_PASSWORD=your_app_password
EMAIL_SENDER_NAME=MT4数据处理系统
# Comma-separated list of recipients
EMAIL_RECIPIENTS=447372703@qq.com,1300893414@qq.com

# -----------------------------------------------------------------------------
# Research / wiki output
# -----------------------------------------------------------------------------
WIKI_RESEARCH_DIR=docs/project-wiki/raw/research

# -----------------------------------------------------------------------------
# Optional: MT5 terminal path (Windows only)
# -----------------------------------------------------------------------------
MT5_TERMINAL_PATH=
