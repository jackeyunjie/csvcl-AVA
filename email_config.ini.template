[EMAIL]
# SMTP服务器配置
smtp_server = smtp.qq.com
smtp_port = 587

# 邮箱账户信息（请填入您的真实信息）
username = your_email@qq.com
password = your_app_password

# 发件人显示名称
sender_name = MT4数据趋势识别处理系统

# 使用说明：
# 1. 将此文件复制为 email_config.ini
# 2. 填入您的真实邮箱和授权码
# 3. 如果使用QQ邮箱，password 应该是授权码，不是登录密码
# 4. 确保 email_config.ini 不会被提交到版本控制系统